{
	"include": [
		"./src",
		"./demo/src",
		"./manual/js",
		"./types"
	],
	"compilerOptions": {
		// File Layout
		"rootDir": ".",
		"outDir": "./build",
		"paths": {
			"postprocessing": ["./src/index.js"],
			"temp/*": ["./temp/*"]
		},
		// Environment Settings
		"module": "esnext",
		"target": "es2025",
		"moduleResolution": "bundler",
		"types": ["node"],
		// Style Options
		"noImplicitReturns": true,
		"noImplicitOverride": true,
		// Other
		"allowJs": true,
		"resolveJsonModule": true,
		"sourceMap": false,
		"skipLibCheck": true
	}
}
